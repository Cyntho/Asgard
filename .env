# Backend
SPRING_PROFILES_ACTIVE=docker

# MySQL-Konfiguration (DB-Container)
MYSQL_DB_NAME=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=3306

# Spring Boot DataSource (verweist auf den Docker-Service "db")
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/app_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=app_user
SPRING_DATASOURCE_PASSWORD=app_password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# JPA Einstellungen (optional, aber üblich)
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect

# JWT
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000 # 15min
JWT_REFRESH_TOKEN_EXPIRATION_MS=1209600000 # 14days

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8080/api/v1 # Must be accessible from the browser, not from inside the container

# Teamspeak
MYSQL_ROOT_PASSWORD=superrootpass
MYSQL_DATABASE=teamspeak
MYSQL_USER=ts3user
MYSQL_PASSWORD=strongpassword

# Backup-Konfiguration
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7

# Teamspeak Bot
BOT_SERVER_HOST=teamspeak
BOT_SERVER_PORT=10011
BOT_QUERY_NAME=admin
BOT_QUERY_PASS=mhwGafTJ
BOT_DISPLAY_NAME=Heimdall
BOT_SERVICE_BASE_URL=http://heimdall:5000
BOT_RECONNECT_ATTEMPTS=5